{
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      ".claude",
      ".pnpm-store",
      "build",
      "node_modules",
      "examples/demo-service/build",
      "examples/demo-service/node_modules"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
