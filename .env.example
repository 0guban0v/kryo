SECRET_KEY_BASE=replace-with-a-long-random-string

# Demo bootstrap identities. `make bootstrap` persists these into the local
# services so the browser logins stay predictable across runs.
BOOTSTRAP_FIZZY_ACCOUNT_NAME=Demo Platform
BOOTSTRAP_FIZZY_OWNER_NAME=Fizzy Admin
# Fizzy uses email + development magic-link verification, not password auth.
BOOTSTRAP_FIZZY_OWNER_EMAIL=fizzy-admin@demo.local
BOOTSTRAP_FIZZY_TOKEN_DESCRIPTION=demo-platform
BOOTSTRAP_FIZZY_TOKEN_PERMISSION=write
BOOTSTRAP_CAMPFIRE_ADMIN_NAME=Platform Admin
BOOTSTRAP_CAMPFIRE_ADMIN_EMAIL=campfire-admin@demo.local
BOOTSTRAP_CAMPFIRE_ADMIN_PASSWORD=campfire-admin
BOOTSTRAP_CAMPFIRE_ROOM_NAME=platform-ops
BOOTSTRAP_CAMPFIRE_BOT_NAME=Kryo
BOOTSTRAP_GITEA_ROOT_URL=http://localhost:3007
BOOTSTRAP_GITEA_ADMIN_NAME=Gitea Admin
BOOTSTRAP_GITEA_ADMIN_USERNAME=gitea-admin
BOOTSTRAP_GITEA_ADMIN_EMAIL=gitea-admin@demo.local
BOOTSTRAP_GITEA_ADMIN_PASSWORD=gitea-admin
BOOTSTRAP_GITEA_SERVICE_NAME=Platform Team
BOOTSTRAP_GITEA_SERVICE_USERNAME=platform-team
BOOTSTRAP_GITEA_SERVICE_EMAIL=platform-team@demo.local
BOOTSTRAP_GITEA_SERVICE_PASSWORD=platform-team
BOOTSTRAP_GITEA_REPO_NAME=dev-sandbox
BOOTSTRAP_GITEA_TOKEN_NAME=kryo-mcp
ONCE_CAMPFIRE_VERSION=v1.4.3
CAMPFIRE_IMAGE_TAG=v1.4.3-msgpack
CAMPFIRE_MSGPACK_VERSION=1.7.5
GRAFANA_ADMIN_USER=grafana-admin@demo.local
GRAFANA_ADMIN_PASSWORD=grafana-admin

# Prefer injecting real secret values via self-hosted Infisical.
# This file should document variable names and local bootstrap settings, not become
# the long-term source of truth for credentials.
#
# For kryo-mcp running inside a compose or cluster network, use service DNS
# names such as `http://kryo-fizzy`, `http://kryo-campfire`, and `http://kryo-gitea:3000/api/v1`.
# For host-run debugging outside
# containers, replace them with the exposed localhost port mappings.

# Fizzy
FIZZY_URL=http://kryo-fizzy
# `make bootstrap` will populate these for the local demo stack.
FIZZY_API_TOKEN=
FIZZY_ACCOUNT_ID=
FIZZY_BOARD_ID=
FIZZY_BOARD_SELECTION=configured

# Campfire
CAMPFIRE_URL=http://kryo-campfire
# `make bootstrap` will populate these for the local demo stack.
CAMPFIRE_BOT_KEY=
CAMPFIRE_ROOM_ID=
CAMPFIRE_ROOM_SELECTION=configured
# Optional: used by the recent-messages resource for direct API reads. When unset,
# the server falls back to the in-memory transcript observed from bot webhooks.
CAMPFIRE_SESSION_COOKIE=
CAMPFIRE_TRANSCRIPT_LIMIT=100
CAMPFIRE_RECENT_MESSAGES_LIMIT=20

# Git forge
# For the local demo flow, prefer a Gitea or Forgejo service reachable
# from the mcp container over a host-access GitHub account.
GIT_FORGE_PROVIDER=gitea
# `make bootstrap` will populate these for the local demo stack.
GIT_FORGE_API_URL=http://kryo-gitea:3000/api/v1
GIT_FORGE_TOKEN=
GIT_FORGE_REPO=
GIT_FORGE_ALLOW_REPO_OVERRIDE=false
GIT_FORGE_DEFAULT_BRANCH=main
GIT_FORGE_MERGE_METHOD=squash
GIT_FORGE_SUPPORTS_CHECK_RUNS=false

# Workflow policy
WORKFLOW_TODO_COLUMN=To Do
WORKFLOW_IN_PROGRESS_COLUMN=In Progress
WORKFLOW_REVIEW_COLUMN=Review
WORKFLOW_BLOCKED_COLUMN=Blocked
WORKFLOW_DONE_LABEL=Done
WORKFLOW_NOT_NOW_LABEL=Not Now
WORKFLOW_TRIAGE_LABEL=Triage
CARD_DESCRIPTION_PREVIEW_LIMIT=500
BOARD_STATUS_VISIBLE_CARDS_LIMIT=5
TROUBLESHOOT_ERROR_LIMIT=1500

# Infisical bootstrap
# Public or self-hosted Infisical API URL for secret delivery.
INFISICAL_URL=https://infisical.internal.example
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_SECRET_PATH=/kryo-mcp
# For generic containers or VMs, use a machine identity via Universal Auth.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# MCP + bot HTTP listener
MCP_TRANSPORT=streamable-http
MCP_HTTP_SESSION_MODE=stateful
MCP_HOST=0.0.0.0
# Comma-separated hostnames accepted on inbound HTTP requests.
# Set this explicitly when exposing kryo behind an ingress or reverse proxy.
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,mcp
# Idle timeout and cap for in-memory stateful MCP sessions.
MCP_SESSION_IDLE_TTL_MS=1800000
MCP_MAX_SESSIONS=100
MCP_PORT=3100
MCP_PATH=/mcp
BOT_WEBHOOK_PATH=/campfire/webhook
# `shared-secret` requires BOT_WEBHOOK_SHARED_SECRET to be set.
# Use `none` only when a trusted ingress or network boundary already protects
# the webhook endpoint.
BOT_WEBHOOK_AUTH=none
BOT_WEBHOOK_SHARED_SECRET=
BOT_WEBHOOK_SHARED_SECRET_HEADER=x-kryo-webhook-secret
REQUEST_TIMEOUT_MS=10000
LOG_LEVEL=info
