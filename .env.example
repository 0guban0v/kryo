SECRET_KEY_BASE=replace-with-a-long-random-string

# Prefer injecting real secret values via self-hosted Infisical.
# This file should document variable names and local bootstrap settings, not become
# the long-term source of truth for credentials.
#
# For kryo-mcp running inside a compose or cluster network, use service DNS
# names such as `http://fizzy` and `http://campfire`. For host-run debugging outside
# containers, replace them with the exposed localhost port mappings.

# Fizzy
FIZZY_URL=http://fizzy
FIZZY_API_TOKEN=replace-with-your-fizzy-token
FIZZY_ACCOUNT_ID=897362094
FIZZY_BOARD_ID=
FIZZY_BOARD_SELECTION=configured

# Campfire
CAMPFIRE_URL=http://campfire
CAMPFIRE_BOT_KEY=
CAMPFIRE_ROOM_ID=
CAMPFIRE_ROOM_SELECTION=configured
# Optional: used by the recent-messages resource for direct API reads. When unset,
# the server falls back to the in-memory transcript observed from bot webhooks.
CAMPFIRE_SESSION_COOKIE=
CAMPFIRE_TRANSCRIPT_LIMIT=100
CAMPFIRE_RECENT_MESSAGES_LIMIT=20

# Git forge
# Provider:
#   github - public GitHub Cloud
#   ghes   - GitHub Enterprise Server
#   gitea  - Gitea or Forgejo using Gitea-compatible auth/API
GIT_FORGE_PROVIDER=github
# Public GitHub:
#   GITHUB_API_URL=https://api.github.com
# GHES:
#   GITHUB_API_URL=https://ghes.internal.example/api/v3
# Gitea / Forgejo:
#   GITHUB_API_URL=https://gitea.internal.example/api/v1
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_REPO=your-org/kryo-mcp
GITHUB_DEFAULT_BRANCH=main
GITHUB_MERGE_METHOD=squash
GIT_FORGE_SUPPORTS_CHECK_RUNS=

# Workflow policy
WORKFLOW_TODO_COLUMN=To Do
WORKFLOW_IN_PROGRESS_COLUMN=In Progress
WORKFLOW_REVIEW_COLUMN=Review
WORKFLOW_BLOCKED_COLUMN=Blocked
WORKFLOW_DONE_LABEL=Done
WORKFLOW_NOT_NOW_LABEL=Not Now
WORKFLOW_TRIAGE_LABEL=Triage
CARD_DESCRIPTION_PREVIEW_LIMIT=500
BOARD_STATUS_VISIBLE_CARDS_LIMIT=5
TROUBLESHOOT_ERROR_LIMIT=1500

# Infisical bootstrap
# Public or self-hosted Infisical API URL for secret delivery.
INFISICAL_URL=https://infisical.internal.example
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev
INFISICAL_SECRET_PATH=/kryo-mcp
# For generic containers or VMs, use a machine identity via Universal Auth.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# MCP + bot HTTP listener
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=3100
MCP_PATH=/mcp
BOT_WEBHOOK_PATH=/campfire/webhook
BOT_WEBHOOK_SHARED_SECRET=
BOT_WEBHOOK_SHARED_SECRET_HEADER=x-kryo-webhook-secret
REQUEST_TIMEOUT_MS=10000
LOG_LEVEL=info
