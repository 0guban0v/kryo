{
  "name": "mission-control-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted MCP server for AI-powered developer workflow orchestration across Fizzy, Campfire, and GitHub.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "mission-control-mcp": "./build/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node build/src/index.js",
    "test": "pnpm run build && node --test build/tests/**/*.test.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "sample-service:build": "pnpm --filter mission-control-sample-service run build",
    "sample-service:dev": "pnpm --filter mission-control-sample-service run dev",
    "sample-service:test": "pnpm --filter mission-control-sample-service run test",
    "sample-service:test:demo": "pnpm --filter mission-control-sample-service run test:demo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.8",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
